{
  "name": "anomalous/msc-last-updated",
  "description": "Display and control the post last-updated date in flexible positions.",
  "type": "wordpress-plugin",
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "squizlabs/php_codesniffer": "^3.10",
    "phpcsstandards/phpcsextra": "^1.2",
    "phpcsstandards/phpcsutils": "^1.1",
    "wp-coding-standards/wpcs": "^3.1",
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "scripts": {
    "lint": "phpcs .",
    "lint-fix": "phpcbf .",
    "i18n:pot": "wp i18n make-pot . languages/micro-site-care-post-last-updated-date.pot --domain=micro-site-care-post-last-updated-date --exclude=node_modules,vendor,.git,tests",
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
