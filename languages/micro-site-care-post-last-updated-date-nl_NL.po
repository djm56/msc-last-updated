#. Plugin Name of the plugin
#: micro-site-care-post-last-updated-date.php
msgid "Micro Site Care: Post Last Updated Date"
msgstr "Micro Site Care: Datum laatste update van bericht"

#. Plugin URI of the plugin
#: micro-site-care-post-last-updated-date.php
msgid "https://anomalous.co.za"
msgstr "https://anomalous.co.za"

#. Description of the plugin
#: micro-site-care-post-last-updated-date.php
msgid "Display and control the post last-updated date in flexible positions."
msgstr ""
"Toon en beheer de datum van de laatste update van berichten op flexibele "
"posities."

#. Author of the plugin
#: micro-site-care-post-last-updated-date.php
msgid "Anomalous Developers"
msgstr "Anomalous Developers"

